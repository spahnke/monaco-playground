{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "npm",
			"script": "dev",
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "silent",
				"revealProblems": "onProblem"
			},
			"problemMatcher": [
				{
					"source": "esbuild",
					"pattern": [
						{
							// ✘ [ERROR] Expected "}" but found "includeInlayEnumMemberValueHints"
							"regexp": "\\[ERROR\\]\\s*(.*)$",
							"message": 1
						},
						{
							// src/contrib/todo-contribution.ts:3:14
							"regexp": "^\\s*([^\\s]*):(\\d+):(\\d+)",
							"file": 1,
							"line": 2,
							"column": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": "build started",
						"endsPattern": "build finished|\\[ERROR\\]"
					}
				},
			]
		},
		{
			"label": "build tests",
			"type": "typescript",
			"tsconfig": "test/tsconfig.json",
			"option": "watch",
			"group": "build",
			"presentation": {
				"reveal": "silent",
				"revealProblems": "onProblem"
			},
			"problemMatcher": [
				"$tsc-watch"
			],
		},
		{
			"label": "serve",
			"type": "npm",
			"script": "serve",
			"isBackground": true,
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": {
				"pattern": {
					// dummy regexp because it's mandatory but we only care about the background pattern
					"regexp": ""
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "@@@@@@@@", // impossible pattern
					"endsPattern": "Server listening on:"
				}
			}
		}
	]
}